# =============================================================================
# ExamEdge Frontend — Environment Variables
# Copy to .env.local for local dev, or set these in your hosting provider
# (Vercel/Netlify project settings) for production.
# =============================================================================

# Base URL of your deployed backend API, INCLUDING the version prefix.
# Example production value: https://api.examedge.in/api/v1
# In local dev you can leave this unset — vite.config.js proxies /api to
# http://localhost:3001 automatically.
VITE_API_URL=http://localhost:3001/api/v1

# Which portal this build is for: student | admin | superadmin
# Controls which shell/nav renders and which routes are reachable.
# If you deploy one app for all three (recommended to start), leave unset —
# the in-app portal switcher handles it. If you deploy three separate Vercel
# projects from the same repo (recommended for production), set this per
# project so each one boots straight into its own portal.
VITE_PORTAL=student
